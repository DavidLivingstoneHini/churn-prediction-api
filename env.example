# ── Application ───────────────────────────────────────────────
APP_ENV=development
APP_NAME=ML Customer Churn Prediction API
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=churn_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://churn_user:change_me_strong_password@postgres:5432/churn_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32  (or PowerShell equivalent)
JWT_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_hex
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML ────────────────────────────────────────────────────────
MODEL_PATH=models/churn_model.pkl
SCALER_PATH=models/scaler.pkl
FAISS_INDEX_PATH=models/faiss.index
TRAINING_DATA_PATH=models/training_data.csv
PSI_THRESHOLD=0.2
DRIFT_CHECK_INTERVAL_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
